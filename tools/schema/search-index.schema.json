{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NovelClaw Search Index",
  "description": "Chapter search index for full-text search — each entry stores chapter text for content search",
  "type": "object",
  "required": ["slug", "lang", "updatedAt", "entries"],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$",
      "description": "Novel slug — must match novel directory name"
    },
    "lang": {
      "type": "string",
      "enum": ["th", "cn", "jp", "kr", "en"],
      "description": "Search index language"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last index rebuild"
    },
    "entries": {
      "type": "array",
      "description": "Searchable chapter entries",
      "items": {
        "type": "object",
        "required": ["num", "title", "text"],
        "properties": {
          "num": {
            "type": "integer",
            "minimum": 1,
            "maximum": 99999
          },
          "title": {
            "type": "string",
            "maxLength": 500,
            "description": "Chapter title (for title search)"
          },
          "text": {
            "type": "string",
            "maxLength": 15000,
            "description": "Chapter content text (capped at 15K chars per entry)"
          }
        }
      }
    }
  }
}
