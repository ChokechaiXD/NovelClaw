{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NovelClaw Translation Job",
  "description": "Job state file in jobs/active, jobs/done, jobs/failed, or jobs/needs_review",
  "type": "object",
  "required": ["slug", "chapter", "mode", "createdAt"],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-zA-Z0-9_-]+$" },
    "chapter": { "type": "integer", "minimum": 1 },
    "mode": { "type": "string", "enum": ["safe", "autopilot", "strict", "draft"] },
    "passes": { "type": "integer", "minimum": 1, "default": 1 },
    "score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "status": { "type": "string", "enum": ["pending", "running", "done", "failed"] },
    "state": { "type": "string" },
    "error": { "type": "string" },
    "reason": { "type": "string" },
    "suggestedCommand": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "durationMs": { "type": "integer", "minimum": 0 }
  }
}
