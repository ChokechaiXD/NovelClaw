{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NovelClaw Glossary",
  "description": "Glossary terms file",
  "type": "object",
  "required": ["terms"],
  "properties": {
    "terms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "thai"],
        "properties": {
          "source": { "type": "string" },
          "thai": { "type": "string" },
          "lock": { "type": "string", "enum": ["locked", "reference", "unlocked"] },
          "category": { "type": "string" }
        }
      }
    }
  }
}
