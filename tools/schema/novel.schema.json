{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NovelClaw Novel Metadata",
  "description": "Canonical novel.json format",
  "type": "object",
  "required": ["slug", "title"],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-zA-Z0-9_-]+$" },
    "title": { "type": "string" },
    "translatedTitle": { "type": "string" },
    "author": { "type": "string" },
    "sourceLang": { "type": "string", "enum": ["cn", "jp", "kr", "en"], "default": "cn" },
    "targetLang": { "type": "string", "enum": ["th", "cn", "jp", "kr", "en"], "default": "th" },
    "status": { "type": "string", "enum": ["ongoing", "complete", "in_progress", "paused", "hiatus"], "default": "ongoing" },
    "totalChapters": { "type": "integer", "minimum": 0 },
    "description": { "type": "string" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
