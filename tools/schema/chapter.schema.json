{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NovelClaw Chapter",
  "description": "Canonical chapter JSON format — SSOT. Auto-generated from contracts.py ChapterV2 Pydantic model.",
  "type": "object",
  "required": ["novelId", "chapterNo", "paragraphs"],
  "properties": {
    "novelId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$",
      "description": "Novel slug — must match novel directory name"
    },
    "chapterNo": {
      "type": "integer",
      "minimum": 1,
      "maximum": 99999,
      "description": "Chapter number — should match filename"
    },
    "sourceLang": {
      "type": "string",
      "pattern": "^(cn|jp|kr|en)$",
      "default": "cn",
      "description": "Source language code"
    },
    "targetLang": {
      "type": "string",
      "pattern": "^(th|cn|jp|kr|en)$",
      "default": "th",
      "description": "Target language code"
    },
    "title": {
      "type": "object",
      "properties": {
        "source": { "type": "string", "description": "Original chapter title" },
        "translated": { "type": "string", "description": "Translated chapter title" }
      },
      "description": "Chapter title in source and translated languages"
    },
    "status": {
      "type": "string",
      "enum": ["translated", "source_only", "source", "legacy"],
      "default": "translated"
    },
    "paragraphs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Array of paragraph strings — canonical content storage"
    },
    "model": {
      "type": "string",
      "default": "unknown",
      "description": "Model name used for translation"
    },
    "provider": {
      "type": "string",
      "default": "unknown",
      "description": "Provider used for translation"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "qualityRecord": {
      "type": "object",
      "description": "Quality metrics at translation time"
    }
  }
}
