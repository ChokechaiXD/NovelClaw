{
  "lang": "zh",
  "name": "Chinese",
  "expected_scripts": ["Han"],
  "allowed_scripts": ["Common", "Inherited"],
  "allowed_digit_sets": ["ASCII"],
  "allow_emoji": true,
  "allowed_span_patterns": [
    {"name": "url", "regex": "https?://[\\w./\\-:?#@!$&'()*+,;=]+", "severity": "pass"},
    {"name": "version", "regex": "v?\\d+\\.\\d+\\.\\d+", "severity": "pass"},
    {"name": "model_name", "regex": "deepseek|gpt|claude|gemma|nemotron", "severity": "pass"},
    {"name": "numeric_unit", "regex": "\\d+(\\.\\d+)?\\s*(%|HP|MP|EXP|ATK|DEF)", "severity": "pass"}
  ],
  "protected_glossary_categories": ["character_name", "place_name", "skill_name"],
  "leak_rules": {
    "fail_if_source_script_ratio_over": 0.01,
    "fail_if_foreign_span_length_over": 20,
    "warn_if_foreign_span_count_over": 3,
    "warn_if_unknown_script_chars": 0
  }
}