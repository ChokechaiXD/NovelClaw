# Node
node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
.venv312/
venv/
env/
ENV/

# Environment / secrets
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Backups (regenerate via `python novelclaw.py backup`)
backups/
# Source backup from 2026-06-14 re-scrape (temporary, can be regenerated)
novels/*/chapters/source_backup_*/

# Build / temp
*.log
tmp_*
.tmp/
*.tmp

# Test
.pytest_cache/
.coverage
htmlcov/
.tox/

# Translator memory — keep first batch in repo, ignore ongoing backups
# (Don't ignore chapters/ — those are the actual translation work)

# CN source files (copyrighted, do NOT push)
novels/*/chapters/source/
**/chapters/source/
# Quarantined source files (copyrighted, do NOT push)
novels/*/chapters/source_dirty/
**/chapters/source_dirty/*.md

# Legacy translations (pre-v2 format, kept for reference but not in repo)
novels/*/chapters/legacy/
**/chapters/legacy/

# Auto-generated DBs (rebuild via `python tools/build_yaml.py`)
# - glossary.db = rebuilt from locked.md/reference.md/auto.md
# - fts_index.db = rebuilt via `python novelclaw.py search-index`
**/glossary.db
**/fts_index.db

# SQLite WAL artifacts (auto-generated by PRAGMA journal_mode=WAL)
*.db-shm
*.db-wal
nul
