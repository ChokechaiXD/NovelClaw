{
  "name": "NovelClaw",
  "workflow_categories": {
    "translation": {
      "default_approach": "python tools/translate.py {range} --score --json",
      "notes": "Use ranges (131-135), not space-separated lists"
    },
    "scraping": {
      "default_source": "qidian.com",
      "tools": ["python requests", "agent-browser CLI"],
      "cf_bypass": "No free tool reliably bypasses Cloudflare in 2026"
    },
    "quality": {
      "scorer": "python tools/scorer.py chapters/ --source source/",
      "threshold": 70
    }
  },
  "model_constraint": "deepseek-v4-flash ONLY (free via openmodel.ai)",
  "provider": "tools/providers/api.py via direct HTTP"
}
