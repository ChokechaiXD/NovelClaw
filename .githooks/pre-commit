#!/usr/bin/env python3
"""Pre-commit hook: validate any staged chapters/*.json files.

Blocks commit if:
  - Schema validation fails (Pydantic)
  - CN/JP leak found in paragraphs or blocks

Warns (doesn't block) if:
  - Validation gates find issues

Configure: git config core.hooksPath .githooks
"""
import json
import re
import subprocess
import sys
from pathlib import Path

REPO = Path(__file__).parent.parent
sys.path.insert(0, str(REPO / "tools"))
from schema import Chapter  # noqa: E402

# CN/JP check — supports both v3 paragraphs and legacy blocks
CN = re.compile(r'[\u4e00-\u9fff]')
JP_KANA = re.compile(r'[\u3040-\u309f\u30a0-\u30ff]')
WHITELIST_ZONES = [
    re.compile(r'【[^】]*】'),
    re.compile(r'《[^》]*》'),
]
# Auto-strip patterns
STRIP_PATTERNS = [
    re.compile(r'^\s*ขอบคุณ\s*นักอ่าน[:：]?.*$', re.MULTILINE),
    re.compile(r'^\s*ขอบคุณ\s*《[^》]*》.*$', re.MULTILINE),
    re.compile(r'^\s*感谢书友.*$', re.MULTILINE),
    re.compile(r'^\s*感谢.*的月票.*$', re.MULTILINE),
    re.compile(r'^\s*感谢书友们的收藏和订阅.*$', re.MULTILINE),
    re.compile(r'^\s*感谢.*(?:收藏|订阅|打赏|月票).*$', re.MULTILINE),
]


def strip_whitelist(text):
    out = text
    for p in WHITELIST_ZONES:
        out = p.sub('', out)
    return out


def should_strip(text):
    return any(p.match(text.strip()) for p in STRIP_PATTERNS)


def check_cn_leak(data):
    """Return list of (idx, char, source) leaks."""
    leaks = []
    # Check paragraphs format (v3)
    for i, para in enumerate(data.get('paragraphs', [])):
        if not para or para in ('(จบบท)', '(End)', '（終）', '(끝)'):
            continue
        for c in CN.findall(para) + JP_KANA.findall(para):
            leaks.append((i, c, 'paragraph'))
    # Check blocks format (legacy)
    for i, block in enumerate(data.get('blocks', [])):
        btype = block.get('type')
        text = block.get('text', '')
        if not text or btype == 'end' or should_strip(text):
            continue
        if btype in ('narration', 'dialogue'):
            for c in CN.findall(text) + JP_KANA.findall(text):
                leaks.append((i, c, btype))
        elif btype in ('system', 'game_title'):
            check = strip_whitelist(text)
            for c in CN.findall(check) + JP_KANA.findall(check):
                leaks.append((i, c, btype))
    return leaks


def main():
    result = subprocess.run(
        ['git', 'diff', '--cached', '--name-only', '--diff-filter=ACM'],
        capture_output=True, text=True, cwd=REPO,
    )
    staged = [
        line.strip()
        for line in result.stdout.splitlines()
        if line.strip().startswith('novels/global-descent/chapters/') and line.strip().endswith('.json')
    ]

    if not staged:
        return 0

    print(f'🪝 pre-commit: validating {len(staged)} ch file(s)...')

    errors = 0
    warnings = 0

    for path_str in staged:
        path = REPO / path_str
        if not path.exists():
            continue
        try:
            data = json.loads(path.read_text(encoding='utf-8'))
        except json.JSONDecodeError as e:
            print(f'  ❌ {path.name}: invalid JSON: {e}')
            errors += 1
            continue

        # 1. Schema check
        try:
            ch = Chapter(**data)
        except Exception as e:
            print(f'  ❌ {path.name}: schema failed: {str(e)[:200]}')
            errors += 1
            continue

        # 2. CN/JP leak check
        cn_leaks = check_cn_leak(data)
        if cn_leaks:
            print(f'  ❌ {path.name}: {len(cn_leaks)} CN/JP leak(s):')
            for i, c, btype in cn_leaks[:3]:
                print(f'      block {i} ({btype}): "{c}"')
            errors += len(cn_leaks)
            continue

        # 3. Validation check (integrated)
        try:
            from tools.validation import validate_translation_quality
            from pathlib import Path
            src_path = Path(REPO) / 'novels' / 'global-descent' / 'chapters' / 'source' / f'{ch.num:04d}.md'
            src_text = src_path.read_text('utf-8') if src_path.exists() else ''
            result = validate_translation_quality(data, src_text)
            if result:
                for w in result.get('warnings', []):
                    print(f'  ⚠️  {path.name}: {w}')
                    warnings += 1
                for e in result.get('errors', []):
                    print(f'  ❌ {path.name}: {e}')
                    errors += 1
        except Exception:
            pass

        if errors == 0:
            print(f'  ✓ {path.name}: schema + validation OK ({len(data.get("blocks", data.get("paragraphs", [])))} blocks)')

    print()
    if errors:
        print(f'❌ pre-commit BLOCKED: {errors} error(s) across {len(staged)} file(s)')
        print('   Fix schema/CN/doctor errors before committing.')
        return 1

    if warnings:
        print(f'⚠️  pre-commit ALLOWED: {warnings} warning(s) (transmittor — review when you can)')
    else:
        print(f'✓ pre-commit PASSED: {len(staged)} ch file(s) clean')

    return 0


if __name__ == '__main__':
    sys.exit(main())
