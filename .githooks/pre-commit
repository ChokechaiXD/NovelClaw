#!/usr/bin/env python3
"""Pre-commit hook: validate any staged chapters/*.json files.

Blocks commit if:
  - Schema validation fails (Pydantic)
  - CN/JP leak found (cn_checker)

Warns (doesn't block) if:
  - Glossary gate sees new terms not yet in glossary
  - Glossary doctor finds warnings

Configure: git config core.hooksPath .githooks
"""
import json
import re
import subprocess
import sys
from pathlib import Path

REPO = Path(__file__).parent.parent
sys.path.insert(0, str(REPO / "tools"))
from schema import Chapter  # noqa: E402

# CN/JP check (inlined for speed — full tool at tools/cn_checker.py)
CN = re.compile(r'[\u4e00-\u9fff]')
JP_KANA = re.compile(r'[\u3040-\u309f\u30a0-\u30ff]')
WHITELIST_ZONES = [
    re.compile(r'【[^】]*】'),
    re.compile(r'《[^》]*》'),
]
# Auto-strip patterns (P'Chok's choice — see tools/cn_checker.py)
STRIP_PATTERNS = [
    re.compile(r'^\s*ขอบคุณ\s*นักอ่าน[:：]?.*$', re.MULTILINE),
    re.compile(r'^\s*ขอบคุณ\s*《[^》]*》.*$', re.MULTILINE),
    re.compile(r'^\s*感谢书友.*$', re.MULTILINE),
    re.compile(r'^\s*感谢.*的月票.*$', re.MULTILINE),
    re.compile(r'^\s*感谢书友们的收藏和订阅.*$', re.MULTILINE),
    re.compile(r'^\s*感谢.*(?:收藏|订阅|打赏|月票).*$', re.MULTILINE),
]


def strip_whitelist(text):
    out = text
    for p in WHITELIST_ZONES:
        out = p.sub('', out)
    return out


def should_strip(text):
    return any(p.match(text.strip()) for p in STRIP_PATTERNS)


def check_cn_leak(data):
    """Return list of (block_idx, char, btype) leaks."""
    leaks = []
    for i, block in enumerate(data.get('blocks', [])):
        btype = block.get('type')
        text = block.get('text', '')
        if not text or btype == 'end_marker' or should_strip(text):
            continue
        if btype in ('narration', 'dialogue'):
            for c in CN.findall(text) + JP_KANA.findall(text):
                leaks.append((i, c, btype))
        elif btype in ('system', 'game_title'):
            check = strip_whitelist(text)
            for c in CN.findall(check) + JP_KANA.findall(check):
                leaks.append((i, c, btype))
    return leaks


def main():
    result = subprocess.run(
        ['git', 'diff', '--cached', '--name-only', '--diff-filter=ACM'],
        capture_output=True, text=True, cwd=REPO,
    )
    staged = [
        line.strip()
        for line in result.stdout.splitlines()
        if line.strip().startswith('novels/global-descent/chapters/') and line.strip().endswith('.json')
    ]

    if not staged:
        return 0

    print(f'🪝 pre-commit: validating {len(staged)} ch file(s)...')

    errors = 0
    warnings = 0

    for path_str in staged:
        path = REPO / path_str
        if not path.exists():
            continue
        try:
            data = json.loads(path.read_text(encoding='utf-8'))
        except json.JSONDecodeError as e:
            print(f'  ❌ {path.name}: invalid JSON: {e}')
            errors += 1
            continue

        # 1. Schema check
        try:
            ch = Chapter(**data)
        except Exception as e:
            print(f'  ❌ {path.name}: schema failed: {str(e)[:200]}')
            errors += 1
            continue

        # 2. CN/JP leak check
        cn_leaks = check_cn_leak(data)
        if cn_leaks:
            print(f'  ❌ {path.name}: {len(cn_leaks)} CN/JP leak(s):')
            for i, c, btype in cn_leaks[:3]:
                print(f'      block {i} ({btype}): "{c}"')
            errors += len(cn_leaks)
            continue

        # 3. Glossary gate (warning only — pre-translate gate ran in workflow)
        try:
            from glossary_gate import scan_chapter
            gate_result = scan_chapter(ch.num)
            if not gate_result.get('gate_passed', True) and 'error' not in gate_result:
                new_terms = [t for t, _ in gate_result.get('terms_new', [])[:5]]
                if new_terms:
                    print(f'  ⚠️  {path.name}: glossary gate sees {len(gate_result["terms_new"])} new term(s): {new_terms}')
                    warnings += 1
        except Exception as e:
            # Gate is informational — never block on it
            pass

        # 4. Doctor (warnings only)
        try:
            from glossary_doctor import load_glossary, validate_chapter
            glossary, alias_map, style_rules = load_glossary()
            issues = validate_chapter(ch.num, glossary, alias_map, style_rules, log_to_db=False)
            ch_errors = [i for i in issues if i.get('severity') == 'error']
            ch_warnings = [i for i in issues if i.get('severity') == 'warning']
            if ch_errors:
                print(f'  ❌ {path.name}: {len(ch_errors)} doctor error(s):')
                for e in ch_errors[:3]:
                    print(f'      {e.get("rule_type", "?")}: {e.get("pattern", "")[:60]}')
                errors += len(ch_errors)
            else:
                w_msg = f', {len(ch_warnings)} warning(s)' if ch_warnings else ''
                print(f'  ✓ {path.name}: schema + CN OK ({len(ch.blocks)} blocks{w_msg})')
                warnings += len(ch_warnings)
        except Exception as e:
            print(f'  ⚠️  {path.name}: doctor unavailable: {e}')

    print()
    if errors:
        print(f'❌ pre-commit BLOCKED: {errors} error(s) across {len(staged)} file(s)')
        print('   Fix schema/CN/doctor errors before committing.')
        return 1

    if warnings:
        print(f'⚠️  pre-commit ALLOWED: {warnings} warning(s) (transmittor — review when you can)')
    else:
        print(f'✓ pre-commit PASSED: {len(staged)} ch file(s) clean')

    return 0


if __name__ == '__main__':
    sys.exit(main())
